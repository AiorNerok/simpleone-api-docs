{
  "serverApi": {
    "SimpleRecord": {
      "name": "SimpleRecord",
      "globalObject": null,
      "description": "Серверный класс для работы с записями базы данных платформы SimpleOne",
      "constructor": "SimpleRecord(tableName)",
      "methods": {
        "addQuery": {
          "signature": "addQuery(field, operator, value)",
          "description": "Добавляет условие выборки",
          "parameters": [
            { "name": "field", "type": "String", "required": true },
            { "name": "operator", "type": "String", "required": false },
            { "name": "value", "type": "Any", "required": false }
          ],
          "returns": "SimpleRecord",
          "example": "task.addQuery('active', true); task.addQuery('subject', 'like', 'email');"
        },
        "addOrCondition": {
          "signature": "addOrCondition(property, operator, value)",
          "description": "Добавляет условие ИЛИ",
          "parameters": [
            { "name": "property", "type": "String", "required": true },
            { "name": "operator", "type": "String", "required": false },
            { "name": "value", "type": "Any", "required": false }
          ],
          "returns": "SimpleRecord"
        },
        "addEncodedQuery": {
          "signature": "addEncodedQuery(condition)",
          "description": "Добавляет закодированное условие",
          "parameters": [{ "name": "condition", "type": "String", "required": true }],
          "returns": "Void"
        },
        "getConditionQuery": {
          "signature": "getConditionQuery()",
          "description": "Возвращает текущее условие запроса",
          "returns": "String"
        },
        "query": {
          "signature": "query()",
          "description": "Применяет запрос для получения выборки",
          "returns": "Void"
        },
        "next": {
          "signature": "next()",
          "description": "Возвращает следующую запись",
          "returns": "SimpleRecord/Boolean"
        },
        "orderBy": {
          "signature": "orderBy(column)",
          "description": "Сортировка по возрастанию",
          "parameters": [{ "name": "column", "type": "String", "required": true }],
          "returns": "Void"
        },
        "orderByDesc": {
          "signature": "orderByDesc(column)",
          "description": "Сортировка по убыванию",
          "parameters": [{ "name": "column", "type": "String", "required": true }],
          "returns": "Void"
        },
        "setLimit": {
          "signature": "setLimit(maxNumRecords)",
          "description": "Ограничивает количество записей",
          "parameters": [{ "name": "maxNumRecords", "type": "Integer", "required": true }],
          "returns": "Void"
        },
        "selectAttributes": {
          "signature": "selectAttributes(attributes)",
          "description": "Выбирает только указанные атрибуты",
          "parameters": [{ "name": "attributes", "type": "String|Array", "required": true }],
          "returns": "SimpleRecord"
        },
        "getRowCount": {
          "signature": "getRowCount()",
          "description": "Количество элементов в выборке",
          "returns": "Integer"
        },
        "get": {
          "signature": "get(propertyOrValue, value)",
          "description": "Загружает запись по ID",
          "parameters": [
            { "name": "propertyOrValue", "type": "String", "required": true },
            { "name": "value", "type": "String", "required": false }
          ],
          "returns": "SimpleRecord"
        },
        "getValue": {
          "signature": "getValue(property)",
          "description": "Возвращает значение атрибута",
          "parameters": [{ "name": "property", "type": "String", "required": true }],
          "returns": "Any"
        },
        "getDisplayValue": {
          "signature": "getDisplayValue(property)",
          "description": "Отображаемое значение",
          "parameters": [{ "name": "property", "type": "String", "required": false }],
          "returns": "String"
        },
        "getAttributes": {
          "signature": "getAttributes()",
          "description": "Все атрибуты записи",
          "returns": "Object"
        },
        "getLabel": {
          "signature": "getLabel(property)",
          "description": "Заголовок поля",
          "parameters": [{ "name": "property", "type": "String", "required": true }],
          "returns": "String"
        },
        "getTitle": {
          "signature": "getTitle(attribute)",
          "description": "Заголовок REM-атрибута",
          "parameters": [{ "name": "attribute", "type": "String", "required": true }],
          "returns": "String"
        },
        "getClassDisplayValue": {
          "signature": "getClassDisplayValue()",
          "description": "Заголовок таблицы",
          "returns": "String"
        },
        "getTableName": {
          "signature": "getTableName()",
          "description": "Системное имя таблицы",
          "returns": "String"
        },
        "getReModelId": {
          "signature": "getReModelId()",
          "description": "ID расширенной модели",
          "returns": "String"
        },
        "getErrors": {
          "signature": "getErrors()",
          "description": "Сообщения об ошибках",
          "returns": "Array<String>"
        },
        "initialize": {
          "signature": "initialize()",
          "description": "Заполняет поля значениями по умолчанию",
          "returns": "Void"
        },
        "insert": {
          "signature": "insert()",
          "description": "Создаёт новую запись",
          "returns": "String (ID)"
        },
        "update": {
          "signature": "update()",
          "description": "Обновляет текущую запись",
          "returns": "String (ID)"
        },
        "updateMultiple": {
          "signature": "updateMultiple()",
          "description": "Обновляет все записи выборки",
          "returns": "Boolean"
        },
        "deleteRecord": {
          "signature": "deleteRecord(id)",
          "description": "Удаляет запись",
          "parameters": [{ "name": "id", "type": "String", "required": false }],
          "returns": "Boolean"
        },
        "deleteMultiple": {
          "signature": "deleteMultiple()",
          "description": "Удаляет записи из выборки",
          "returns": "Boolean"
        },
        "setValue": {
          "signature": "setValue(property, value)",
          "description": "Устанавливает значение поля",
          "parameters": [
            { "name": "property", "type": "String", "required": true },
            { "name": "value", "type": "Any", "required": true }
          ],
          "returns": "Void"
        },
        "setMultipleValue": {
          "signature": "setMultipleValue(property, value)",
          "description": "Значение для всех записей выборки",
          "parameters": [
            { "name": "property", "type": "String", "required": true },
            { "name": "value", "type": "Any", "required": true }
          ],
          "returns": "Void"
        },
        "setReModelId": {
          "signature": "setReModelId(reModelId)",
          "description": "Устанавливает ID расширенной модели",
          "parameters": [{ "name": "reModelId", "type": "String", "required": true }],
          "returns": "Void"
        },
        "canCreate": {
          "signature": "canCreate()",
          "description": "Право создания записей",
          "returns": "Boolean"
        },
        "canRead": {
          "signature": "canRead()",
          "description": "Право просмотра записей",
          "returns": "Boolean"
        },
        "canUpdate": {
          "signature": "canUpdate()",
          "description": "Право редактирования",
          "returns": "Boolean"
        },
        "canDelete": {
          "signature": "canDelete()",
          "description": "Право удаления записей",
          "returns": "Boolean"
        },
        "hasAttachment": {
          "signature": "hasAttachment()",
          "description": "Наличие вложений",
          "returns": "Boolean"
        },
        "isTableVcsEnabled": {
          "signature": "isTableVcsEnabled()",
          "description": "Контроль версий таблицы",
          "returns": "Boolean"
        },
        "matchesCondition": {
          "signature": "matchesCondition(condition)",
          "description": "Соответствие условию",
          "parameters": [{ "name": "condition", "type": "String", "required": true }],
          "returns": "Boolean"
        },
        "getJournalInput": {
          "signature": "getJournalInput(name)",
          "description": "Объект поля Journal Input",
          "parameters": [{ "name": "name", "type": "String", "required": true }],
          "returns": "Object"
        },
        "setAbortAction": {
          "signature": "setAbortAction(flag, message)",
          "description": "Прерывает операцию",
          "parameters": [
            { "name": "flag", "type": "Boolean", "required": true },
            { "name": "message", "type": "String", "required": false }
          ],
          "returns": "Void"
        },
        "silentMode": {
          "signature": "silentMode(enable)",
          "description": "Обновление без бизнес-логики",
          "parameters": [{ "name": "enable", "type": "Boolean", "required": false, "default": true }],
          "returns": "Void"
        }
      }
    },
    "SimpleAttachment": {
      "name": "SimpleAttachment",
      "globalObject": null,
      "description": "Серверный класс для работы с вложениями (файлами)",
      "constructor": "SimpleAttachment()",
      "methods": {
        "base64Decode": {
          "signature": "base64Decode(data, strict)",
          "description": "Декодирование Base64 → ASCII",
          "parameters": [
            { "name": "data", "type": "String", "required": true },
            { "name": "strict", "type": "Boolean", "required": false, "default": true }
          ],
          "returns": "String"
        },
        "base64Encode": {
          "signature": "base64Encode(data)",
          "description": "Кодирование ASCII → Base64",
          "parameters": [{ "name": "data", "type": "String", "required": true }],
          "returns": "String"
        },
        "copy": {
          "signature": "copy(sourceTableName, sourceID, targetTableName, targetID)",
          "description": "Копирование вложений между записями",
          "parameters": [
            { "name": "sourceTableName", "type": "String", "required": true },
            { "name": "sourceID", "type": "String", "required": true },
            { "name": "targetTableName", "type": "String", "required": true },
            { "name": "targetID", "type": "String", "required": true }
          ],
          "returns": "Boolean"
        },
        "deleteAttachment": {
          "signature": "deleteAttachment(attachmentID)",
          "description": "Удаление вложения",
          "parameters": [{ "name": "attachmentID", "type": "String", "required": true }],
          "returns": "Void"
        },
        "getAttachmentUrlById": {
          "signature": "getAttachmentUrlById(attachmentId)",
          "description": "URL вложения в S3",
          "parameters": [{ "name": "attachmentId", "type": "String", "required": true }],
          "returns": "String"
        },
        "getContent": {
          "signature": "getContent(attachmentId)",
          "description": "Текстовое содержимое вложения",
          "parameters": [{ "name": "attachmentId", "type": "SimpleRecord", "required": true }],
          "returns": "String/Object|null"
        },
        "readBase64": {
          "signature": "readBase64(attachmentId)",
          "description": "Чтение вложения как Base64 (до 10 Мб)",
          "parameters": [{ "name": "attachmentId", "type": "String", "required": true }],
          "returns": "String"
        },
        "rename": {
          "signature": "rename(attachmentId, fileName)",
          "description": "Переименование вложения",
          "parameters": [
            { "name": "attachmentId", "type": "String", "required": true },
            { "name": "fileName", "type": "String", "required": true }
          ],
          "returns": "Void"
        },
        "write": {
          "signature": "write(documentId, fileName, content, mimeContentType)",
          "description": "Создание вложения из строки",
          "parameters": [
            { "name": "documentId", "type": "String", "required": true },
            { "name": "fileName", "type": "String", "required": true },
            { "name": "content", "type": "String", "required": true },
            { "name": "mimeContentType", "type": "String", "required": true }
          ],
          "returns": "String|null"
        },
        "writeBase64": {
          "signature": "writeBase64(documentId, fileName, base64, mimeContentType)",
          "description": "Создание вложения из Base64",
          "parameters": [
            { "name": "documentId", "type": "String", "required": true },
            { "name": "fileName", "type": "String", "required": true },
            { "name": "base64", "type": "String", "required": true },
            { "name": "mimeContentType", "type": "String", "required": true }
          ],
          "returns": "String|null"
        }
      }
    },
    "SimpleSystem": {
      "name": "SimpleSystem",
      "globalObject": "ss",
      "description": "Класс для получения информации о системе, текущем пользователе и других системных данных",
      "methods": {
        "addInfoMessage": {
          "signature": "addInfoMessage(message, params)",
          "description": "Показать информационное сообщение",
          "parameters": [
            { "name": "message", "type": "String", "required": true },
            { "name": "params", "type": "Object", "required": false }
          ],
          "returns": "Void",
          "checkACL": false
        },
        "addErrorMessage": {
          "signature": "addErrorMessage(message, params)",
          "description": "Показать сообщение об ошибке",
          "parameters": [
            { "name": "message", "type": "String", "required": true },
            { "name": "params", "type": "Object", "required": false }
          ],
          "returns": "Void",
          "checkACL": false
        },
        "addSuccessMessage": {
          "signature": "addSuccessMessage(message, params)",
          "description": "Показать сообщение об успехе",
          "parameters": [
            { "name": "message", "type": "String", "required": true },
            { "name": "params", "type": "Object", "required": false }
          ],
          "returns": "Void",
          "checkACL": false
        },
        "info": {
          "signature": "info(message)",
          "description": "Информационное сообщение в sys_log",
          "parameters": [{ "name": "message", "type": "Any", "required": true }],
          "returns": "Void"
        },
        "debug": {
          "signature": "debug(message)",
          "description": "Отладочное сообщение",
          "parameters": [{ "name": "message", "type": "Any", "required": true }],
          "returns": "Void"
        },
        "warning": {
          "signature": "warning(message)",
          "description": "Предупреждение",
          "parameters": [{ "name": "message", "type": "Any", "required": true }],
          "returns": "Void"
        },
        "error": {
          "signature": "error(message)",
          "description": "Сообщение об ошибке",
          "parameters": [{ "name": "message", "type": "Any", "required": true }],
          "returns": "Void"
        },
        "eventQueue": {
          "signature": "eventQueue(name, current, param_1...param_5)",
          "description": "Поставить событие в очередь",
          "parameters": [
            { "name": "name", "type": "String", "required": true },
            { "name": "current", "type": "SimpleRecord", "required": true },
            { "name": "param_1..5", "type": "String", "required": false }
          ],
          "returns": "Void",
          "checkACL": true
        },
        "eventQueueScheduled": {
          "signature": "eventQueueScheduled(name, current, process_started_at, param_1...param_5)",
          "description": "Поставить событие в очередь по расписанию",
          "parameters": [
            { "name": "name", "type": "String", "required": true },
            { "name": "current", "type": "SimpleRecord", "required": true },
            { "name": "process_started_at", "type": "SimpleDateTime", "required": true },
            { "name": "param_1..5", "type": "String", "required": false }
          ],
          "returns": "Void",
          "checkACL": true
        },
        "generateResetToken": {
          "signature": "generateResetToken()",
          "description": "Токен для сброса пароля",
          "returns": "String"
        },
        "generateUrlAction": {
          "signature": "generateUrlAction(userId, script, expire)",
          "description": "URL для выполнения скрипта",
          "parameters": [
            { "name": "userId", "type": "String", "required": true },
            { "name": "script", "type": "String", "required": true },
            { "name": "expire", "type": "String", "required": true }
          ],
          "returns": "String"
        },
        "getApplicationId": {
          "signature": "getApplicationId()",
          "description": "ID приложения",
          "returns": "String",
          "checkACL": true
        },
        "getProperty": {
          "signature": "getProperty(name)",
          "description": "Получить системное свойство",
          "parameters": [{ "name": "name", "type": "String", "required": true }],
          "returns": "String|null",
          "checkACL": true
        },
        "setProperty": {
          "signature": "setProperty(name, value, description)",
          "description": "Установить системное свойство",
          "parameters": [
            { "name": "name", "type": "String", "required": true },
            { "name": "value", "type": "String", "required": true },
            { "name": "description", "type": "String", "required": false }
          ],
          "returns": "Void",
          "checkACL": true
        },
        "getSession": {
          "signature": "getSession()",
          "description": "Информация о сессии",
          "returns": "SimpleSession",
          "checkACL": false
        },
        "getUser": {
          "signature": "getUser()",
          "description": "Объект текущего пользователя",
          "returns": "SimpleRecord",
          "checkACL": true
        },
        "getUserID": {
          "signature": "getUserID()",
          "description": "ID текущего пользователя",
          "returns": "String",
          "checkACL": true
        },
        "getDocIdByIds": {
          "signature": "getDocIdByIds(tableId, recordId)",
          "description": "Document ID по ID таблицы и записи",
          "parameters": [
            { "name": "tableId", "type": "String", "required": true },
            { "name": "recordId", "type": "String", "required": true }
          ],
          "returns": "String (UUID)"
        },
        "getTableIdByDocId": {
          "signature": "getTableIdByDocId(docId)",
          "description": "ID таблицы по Document ID",
          "parameters": [{ "name": "docId", "type": "String", "required": true }],
          "returns": "String"
        },
        "getRecordIdByDocId": {
          "signature": "getRecordIdByDocId(docId)",
          "description": "ID записи по Document ID",
          "parameters": [{ "name": "docId", "type": "String", "required": true }],
          "returns": "String"
        },
        "hasRole": {
          "signature": "hasRole(role)",
          "description": "Проверка роли (включая admin)",
          "parameters": [{ "name": "role", "type": "String", "required": true }],
          "returns": "Boolean"
        },
        "importIncludeScript": {
          "signature": "importIncludeScript(name)",
          "description": "Импорт внешнего скрипта",
          "parameters": [{ "name": "name", "type": "String", "required": true }],
          "returns": "Boolean"
        },
        "setRedirect": {
          "signature": "setRedirect(url)",
          "description": "Перенаправление на URL",
          "parameters": [{ "name": "url", "type": "String", "required": false }],
          "returns": "Void"
        },
        "getLogoURL": {
          "signature": "getLogoURL()",
          "description": "Ссылка на логотип",
          "returns": "String"
        },
        "getLogoBase64": {
          "signature": "getLogoBase64()",
          "description": "Логотип в Base64",
          "returns": "String"
        }
      }
