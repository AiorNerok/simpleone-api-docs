{
  "clientApi": {
    "s_i18n": {
      "name": "s_i18n",
      "globalObject": "s_i18n",
      "description": "Класс для работы с переводами и локализацией сообщений в системе",
      "methods": {
        "getMessage": {
          "signature": "getMessage(msgKey, config, callback)",
          "description": "Возвращает одну переведённую строку",
          "async": true,
          "parameters": [
            { "name": "msgKey", "type": "String", "required": true, "description": "Ключ сообщения" },
            { "name": "config", "type": "Object", "required": false, "description": "Конфигурация: { language, category, params }" },
            { "name": "callback", "type": "Function", "required": false, "description": "Функция обратного вызова" }
          ],
          "returns": "String",
          "example": "await s_i18n.getMessage('Description', { params: {serviceName: 'Почта'}, language: 'ru' }, (response) => console.log(response));"
        },
        "getMessages": {
          "signature": "getMessages(msgKeys, config, callback)",
          "description": "Возвращает массив переведённых строк",
          "async": true,
          "parameters": [
            { "name": "msgKeys", "type": "Array<String>", "required": true, "description": "Массив ключей сообщений" },
            { "name": "config", "type": "Object", "required": false, "description": "Конфигурация" },
            { "name": "callback", "type": "Function", "required": false, "description": "Функция обратного вызова" }
          ],
          "returns": "Array<String>"
        }
      }
    },
    "SimpleAjax": {
      "name": "SimpleAjax",
      "globalObject": null,
      "description": "Позволяет клиентскому скрипту выполнять серверный код, используя Внешний скрипт",
