      "methods": {
        "addParam": {
          "signature": "addParam(paramName, paramValue)",
          "description": "Передаёт имя и значение параметра серверной функции",
          "parameters": [
            { "name": "paramName", "type": "String", "required": true, "description": "Имя параметра (должен начинаться с sysparm_)" },
            { "name": "paramValue", "type": "String", "required": true, "description": "Значение параметра" }
          ],
          "returns": "Void"
        },
        "getXML": {
          "signature": "getXML(callback)",
          "description": "Отправляет запрос на сервер для выполнения метода",
          "parameters": [
            { "name": "callback", "type": "Function", "required": true, "description": "Функция обратного вызова" }
          ],
          "returns": "Void"
        },
        "runScript": {
          "signature": "runScript(scriptValue, tableName, callback)",
          "description": "Запускает скрипт на заданной таблице с учётом ACL",
          "async": true,
          "parameters": [
            { "name": "scriptValue", "type": "String", "required": true, "description": "Код скрипта" },
            { "name": "tableName", "type": "String", "required": false, "description": "Имя таблицы" },
            { "name": "callback", "type": "Function", "required": false, "description": "Функция обратного вызова" }
          ],
          "returns": "Void"
        },
        "runAdminScript": {
          "signature": "runAdminScript(scriptValue, tableName, callback)",
          "description": "Запускает скрипт от имени администратора (без ACL)",
          "async": true,
          "parameters": [
            { "name": "scriptValue", "type": "String", "required": true, "description": "Код скрипта" },
            { "name": "tableName", "type": "String", "required": false, "description": "Имя таблицы" },
            { "name": "callback", "type": "Function", "required": false, "description": "Функция обратного вызова" }
          ],
          "returns": "Void"
        }
      }
    },
