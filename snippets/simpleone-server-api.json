  "simpleRecord_new": {
    "prefix": "simpleRecord_new",
    "body": [
      "const ${1:record} = new SimpleRecord('${2:tableName}');"
    ],
    "description": "Создать новый SimpleRecord"
  },
  "simpleRecord_query": {
    "prefix": "simpleRecord_query",
    "body": [
      "const ${1:record} = new SimpleRecord('${2:tableName}');",
      "${1:record}.addQuery('${3:field}', '${4:value}');",
      "${1:record}.orderBy('${5:column}');",
      "${1:record}.setLimit(${6:10});",
      "${1:record}.query();",
      "while (${1:record}.next()) {",
      "    ${7:console.log(${1:record}.${8:number});}",
      "}"
    ],
    "description": "Выполнить запрос с фильтрацией"
  },
  "simpleRecord_get": {
    "prefix": "simpleRecord_get",
    "body": [
      "const ${1:record} = new SimpleRecord('${2:tableName}');",
      "${1:record}.get('${3:sys_id}');",
      "${4:console.log(${1:record}.${5:number});}"
    ],
    "description": "Получить запись по ID"
  },
  "simpleRecord_insert": {
    "prefix": "simpleRecord_insert",
    "body": [
      "const ${1:record} = new SimpleRecord('${2:tableName}');",
      "${1:record}.${3:field} = '${4:value}';",
      "const insertedID = ${1:record}.insert();",
      "${5:console.log('Inserted ID:', insertedID);}"
    ],
    "description": "Вставить новую запись"
  },
  "simpleRecord_update": {
    "prefix": "simpleRecord_update",
    "body": [
      "const ${1:record} = new SimpleRecord('${2:tableName}');",
      "${1:record}.get('${3:sys_id}');",
      "${1:record}.${4:field} = '${5:value}';",
      "const updatedID = ${1:record}.update();",
      "${6:console.log('Updated ID:', updatedID);}"
    ],
    "description": "Обновить запись"
  },
  "simpleRecord_deleteRecord": {
    "prefix": "simpleRecord_deleteRecord",
    "body": [
      "const ${1:record} = new SimpleRecord('${2:tableName}');",
      "${1:record}.get('${3:sys_id}');",
      "const deleted = ${1:record}.deleteRecord();",
      "${4:console.log('Deleted:', deleted);}"
    ],
    "description": "Удалить запись"
  },
  "simpleRecord_setValue": {
    "prefix": "simpleRecord_setValue",
    "body": [
      "${1:record}.setValue('${2:property}', ${3:value});"
    ],
    "description": "Установить значение поля"
  },
  "simpleRecord_getValue": {
    "prefix": "simpleRecord_getValue",
    "body": [
      "const value = ${1:record}.getValue('${2:property}');",
      "${3:console.log(value);}"
    ],
    "description": "Получить значение поля"
  },
  "simpleRecord_getDisplayValue": {
    "prefix": "simpleRecord_getDisplayValue",
    "body": [
      "const displayValue = ${1:record}.getDisplayValue('${2:property}');",
      "${3:console.log(displayValue);}"
    ],
    "description": "Получить отображаемое значение поля"
  },
  "simpleRecord_canCreate": {
    "prefix": "simpleRecord_canCreate",
    "body": [
      "const ${1:record} = new SimpleRecord('${2:tableName}');",
      "if (${1:record}.canCreate()) {",
      "    ${3:// право создания есть}",
      "} else {",
      "    ${4:// права создания нет}",
      "}"
    ],
    "description": "Проверить право создания записей"
  },
  "simpleRecord_canRead": {
    "prefix": "simpleRecord_canRead",
    "body": [
      "if (${1:record}.canRead()) {",
      "    ${2:// право чтения есть}",
      "}"
    ],
    "description": "Проверить право просмотра записей"
  },
  "simpleRecord_canUpdate": {
    "prefix": "simpleRecord_canUpdate",
    "body": [
      "if (${1:record}.canUpdate()) {",
      "    ${2:// право редактирования есть}",
      "}"
    ],
    "description": "Проверить право редактирования записей"
  },
  "simpleRecord_canDelete": {
    "prefix": "simpleRecord_canDelete",
    "body": [
      "if (${1:record}.canDelete()) {",
      "    ${2:// право удаления есть}",
      "}"
    ],
    "description": "Проверить право удаления записей"
  },
  "simpleRecord_silentMode": {
    "prefix": "simpleRecord_silentMode",
    "body": [
      "${1:record}.silentMode();",
      "${1:record}.setMultipleValue('${2:field}', '${3:value}');",
      "${1:record}.updateMultiple();"
    ],
    "description": "Обновить записи без бизнес-логики"
  },
  "simpleRecord_setAbortAction": {
    "prefix": "simpleRecord_setAbortAction",
    "body": [
      "if (${1:condition}) {",
      "    current.setAbortAction(true, '${2:Сообщение об ошибке}');",
      "}"
    ],
    "description": "Прервать операцию с сообщением"
  },
  "simpleRecord_journalInput": {
    "prefix": "simpleRecord_journalInput",
    "body": [
      "const ${1:journalField} = current.getJournalInput('${2:work_notes}');",
      "${1:journalField}.setComment('${3:message}', '${4:author}');"
    ],
    "description": "Добавить комментарий в Journal Input поле"
  },
  "simpleAttachment_base64Decode": {
    "prefix": "simpleAttachment_base64Decode",
    "body": [
      "const attach = new SimpleAttachment();",
      "const result = attach.base64Decode('${1:base64String}');",
      "${2:console.log(result);}"
    ],
    "description": "Декодировать Base64 в ASCII"
  },
  "simpleAttachment_base64Encode": {
    "prefix": "simpleAttachment_base64Encode",
    "body": [
      "const attach = new SimpleAttachment();",
      "const encoded = attach.base64Encode('${1:asciiString}');",
      "${2:console.log(encoded);}"
    ],
    "description": "Кодировать ASCII в Base64"
  },
  "simpleAttachment_write": {
    "prefix": "simpleAttachment_write",
    "body": [
      "const simpleAttach = new SimpleAttachment();",
      "const attachID = simpleAttach.write(",
      "    ss.getDocIdByIds('${1:tableName}', '${2:sys_id}'),",
      "    '${3:filename.txt}',",
      "    '${4:content}',",
      "    '${5:text/plain}'",
      ");",
      "${6:console.log('Attachment ID:', attachID);}"
    ],
    "description": "Создать вложение из строки"
  },
  "simpleAttachment_writeBase64": {
    "prefix": "simpleAttachment_writeBase64",
    "body": [
      "const simpleAttach = new SimpleAttachment();",
      "const attachID = simpleAttach.writeBase64(",
      "    ss.getDocIdByIds('${1:tableName}', '${2:sys_id}'),",
      "    '${3:filename.bin}',",
      "    '${4:base64Data}',",
      "    '${5:application/octet-stream}'",
      ");"
    ],
    "description": "Создать вложение из Base64"
  },
  "simpleAttachment_readBase64": {
    "prefix": "simpleAttachment_readBase64",
    "body": [
      "const read = new SimpleAttachment();",
      "const base64Data = read.readBase64('${1:attachmentId}');",
      "${2:console.log(base64Data);}"
    ],
    "description": "Прочитать вложение как Base64"
  },
  "simpleAttachment_copy": {
    "prefix": "simpleAttachment_copy",
    "body": [
      "const attach = new SimpleAttachment();",
      "const copied = attach.copy(",
      "    '${1:sourceTableName}', '${2:sourceID}',",
      "    '${3:targetTableName}', '${4:targetID}'",
      ");",
      "${5:console.log('Copied:', copied);}"
    ],
    "description": "Копировать вложения между записями"
  },
  "simpleAttachment_getAttachmentUrlById": {
    "prefix": "simpleAttachment_getAttachmentUrlById",
    "body": [
      "const simpleAttach = new SimpleAttachment();",
      "const url = simpleAttach.getAttachmentUrlById('${1:attachmentId}');",
      "${2:console.log(url);}"
    ],
    "description": "Получить URL вложения в S3"
  },
  "ss_eventQueue": {
    "prefix": "ss_eventQueue",
    "body": [
