    ],
    "description": "Импортировать внешний скрипт"
  },
  "ss_setRedirect": {
    "prefix": "ss_setRedirect",
    "body": [
      "ss.setRedirect('${1:/record/task?sys_id=ID}');"
    ],
    "description": "Перенаправить на URL"
  },
  "simpleRestRequest_execute": {
    "prefix": "simpleRestRequest_execute",
    "body": [
      "const request = sws.restRequestV1('${1:requestName}', '${2:methodName}');",
      "request.setStringParameter('${3:paramName}', '${4:paramValue}');",
      "const response = request.execute();",
      "if (response.haveError()) {",
      "    ${5:ss.error('Ошибка при выполнении запроса');}",
      "} else {",
      "    ${6:const body = response.getBody();}",
      "    ${7:console.log(body);}",
      "}"
    ],
    "description": "Выполнить REST запрос"
  },
  "simpleRestRequest_manual": {
    "prefix": "simpleRestRequest_manual",
    "body": [
      "const request = sws.restRequestV1();",
      "request.setRequestUrl('${1:https://api.example.com/endpoint}');",
      "request.setRequestMethod('${2:GET}');",
      "request.setRequestHeader('Content-type', 'application/json');",
      "const response = request.execute();",
      "${3:console.log(response.getBody());}"
    ],
    "description": "Выполнить REST запрос с ручной настройкой"
  },
  "simpleRestRequest_auth": {
    "prefix": "simpleRestRequest_auth",
    "body": [
      "const request = sws.restRequestV1();",
      "request.setRequestUrl('${1:https://api.example.com/auth}');",
      "request.setRequestMethod('POST');",
      "request.setBasicAuth('${2:username}', '${3:password}');",
      "const response = request.execute();",
      "${4:const authKey = JSON.parse(response.getBody()).data.auth_key;}"
    ],
    "description": "Выполнить REST запрос с авторизацией"
  },
  "simpleRestResponse_getBody": {
    "prefix": "simpleRestResponse_getBody",
    "body": [
      "const body = response.getBody();",
      "${1:console.log(body);}"
    ],
    "description": "Получить тело ответа REST"
  },
  "simpleRestResponse_getStatusCode": {
    "prefix": "simpleRestResponse_getStatusCode",
    "body": [
      "const statusCode = response.getStatusCode();",
      "${1:console.log(statusCode);}"
    ],
    "description": "Получить HTTP код состояния"
  },
  "simpleWorkflow_start": {
    "prefix": "simpleWorkflow_start",
    "body": [
      "const workflowManager = new SimpleWorkflow('${1:workflowId}');",
      "const context = workflowManager.start(current);",
      "if (context.state === 'finished') {",
      "    ${2:ss.info('Рабочий процесс завершен!');}",
      "}"
    ],
    "description": "Запустить рабочий процесс"
  },
  "simpleWorkflow_cancel": {
    "prefix": "simpleWorkflow_cancel",
    "body": [
      "const simpleWorkflow = new SimpleWorkflow('${1:workflowId}');",
      "if (simpleWorkflow.hasActiveContexts(current)) {",
      "    simpleWorkflow.cancel(current);",
      "}"
    ],
    "description": "Отменить активные контексты workflow"
  },
  "simpleWorkflow_startSubflow": {
    "prefix": "simpleWorkflow_startSubflow",
    "body": [
      "const workflowManager = new SimpleWorkflow();",
      "const subflowContext = workflowManager.startSubflow(",
      "    activity, current, '${1:subflowWorkflowId}'",
      ");",
      "${2:console.log(subflowContext.state);}"
    ],
    "description": "Запустить подпроцесс workflow"
  },
  "simpleSearch_search": {
    "prefix": "simpleSearch_search",
    "body": [
      "const searchManager = new SimpleSearch();",
      "const results = searchManager.search('${1:text}', ['${2:tableId}']);",
      "results.forEach(foundRecord => {",
      "    ${3:ss.info(foundRecord.getTableName() + '/' + foundRecord.sys_id);}",
      "});"
    ],
    "description": "Выполнить полнотекстовый поиск"
  },
  "simpleSearch_recreateIndices": {
    "prefix": "simpleSearch_recreateIndices",
    "body": [
      "const searchManager = new SimpleSearch();",
      "searchManager.recreateIndicesByTableName('${1:tableName}');"
    ],
    "description": "Переиндексировать таблицу"
  },
  "simpleMail_checkConnection": {
    "prefix": "simpleMail_checkConnection",
    "body": [
      "const mail = new SimpleMail();",
      "if (mail.checkConnection(current)) {",
      "    ss.addInfoMessage('Соединение установлено');",
      "} else {",
      "    ss.addErrorMessage('Соединение не установлено');",
      "}"
    ],
    "description": "Проверить соединение с почтовым сервером"
  },
  "simpleCache_resetCacheSystemUrl": {
    "prefix": "simpleCache_resetCacheSystemUrl",
    "body": [
      "const cacheSystem = new SimpleCache();",
      "const result = cacheSystem.resetCacheSystemUrl();",
      "if (result) {",
      "    ${1:ss.info('Кэш успешно сброшен');}",
      "}"
    ],
    "description": "Сбросить кэш URL"
  },
  "simpleEngine_getAllEngines": {
    "prefix": "simpleEngine_getAllEngines",
    "body": [
      "ss.importIncludeScript('SimpleEngine');",
      "const engines = SimpleEngine.getAllEngines();",
      "${1:console.log(engines);}"
    ],
    "description": "Получить список всех механизмов"
  },
  "simpleEngine_isEngineEnable": {
    "prefix": "simpleEngine_isEngineEnable",
    "body": [
      "const engine = new SimpleEngine('${1:Engine Name}');",
      "if (engine.isEngineEnable('${2:tableName}')) {",
      "    ${3:ss.info('Механизм включен');}",
      "}"
    ],
    "description": "Проверить включён ли механизм для таблицы"
  },
  "simpleTable_getParentTables": {
    "prefix": "simpleTable_getParentTables",
    "body": [
      "const table = new SimpleTable('${1:tableName}');",
      "const parents = table.getParentTables();",
      "${2:console.log('Родительская таблица:', parents[0].name);}"
    ],
    "description": "Получить родительские таблицы"
  },
  "simpleTable_getChildTables": {
    "prefix": "simpleTable_getChildTables",
    "body": [
      "const table = new SimpleTable('${1:tableName}');",
      "const children = table.getChildTables();",
      "for (let child of children) {",
      "    ${2:ss.info('Дочерняя таблица: ' + child.name);}",
      "}"
    ],
    "description": "Получить дочерние таблицы"
  },
  "simpleTemplate_applyTo": {
    "prefix": "simpleTemplate_applyTo",
    "body": [
      "const template = new SimpleTemplate('${1:templateName}');",
      "const record = new SimpleRecord('${2:tableName}');",
      "template.applyTo(record);",
      "${3:record.insert();}"
    ],
    "description": "Применить шаблон к записи"
  },
  "simpleTemplate_createBySimpleRecord": {
    "prefix": "simpleTemplate_createBySimpleRecord",
    "body": [
      "const record = new SimpleRecord('${1:tableName}');",
      "record.get('${2:sys_id}');",
      "const template = new SimpleTemplate();",
      "const templateId = template.createBySimpleRecord(record, '${3:templateName}');",
      "${4:console.log(templateId);}"
    ],
    "description": "Создать шаблон из SimpleRecord"
  },
  "simpleVcs_importRetrievedPack": {
    "prefix": "simpleVcs_importRetrievedPack",
    "body": [
      "const vcs = new SimpleVcs();",
      "if (!vcs.importRetrievedPack(current.sys_id)) {",
      "    ss.addErrorMessage('Ошибка импорта данных');",
      "    return;",
      "}",
      "if (!vcs.applyRetrievedPack(current.sys_id)) {",
      "    ss.addErrorMessage('Ошибка применения данных');",
      "}"
    ],
    "description": "Импортировать и применить пакет VCS"
  },
  "simpleVcs_mergeLocalPacks": {
    "prefix": "simpleVcs_mergeLocalPacks",
    "body": [
      "const vcsLocalPackId = [",
      "    '${1:packId1}',",
      "    '${2:packId2}'",
      "];",
      "const vcs = new SimpleVcs();",
      "const mergedId = vcs.mergeLocalPacks(vcsLocalPackId, '${3:mergedName}', '${4:mergedDescription}');",
      "${5:console.log('ID объединенного пакета:', mergedId);}"
    ],
    "description": "Объединить локальные пакеты VCS"
  },
  "simpleVcs_createTableSnapshot": {
    "prefix": "simpleVcs_createTableSnapshot",
    "body": [
      "const vcs = new SimpleVcs();",
      "const versionCount = vcs.createTableSnapshot('${1:tableName}');",
      "${2:console.log('Создано версий:', versionCount);}"
    ],
    "description": "Создать снимок версий таблицы"
  },
  "simpleVcs_rollback": {
    "prefix": "simpleVcs_rollback",
    "body": [
      "const vcs = new SimpleVcs();",
      "vcs.rollback('${1:packId}');"
    ],
    "description": "Откатить локальный пакет"
  },
  "simpleDateTime_new": {
    "prefix": "simpleDateTime_new",
    "body": [
      "const dateTime = new SimpleDateTime();",
      "dateTime.addDays(${1:3});",
      "${2:console.log(dateTime.getValue());}"
    ],
    "description": "Создать объект даты и времени"
  },
  "simpleSession_get": {
    "prefix": "simpleSession_get",
    "body": [
      "const session = ss.getSession();",
      "${1:console.log(session.getClientIP());}"
    ],
    "description": "Получить информацию о сессии"
  }
}
