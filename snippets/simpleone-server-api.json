      "ss.eventQueueScheduled('${2:eventName}', current, processTime, ${3:param_1});"
    ],
    "description": "Поставить событие в очередь по расписанию"
  },
  "ss_generateResetToken": {
    "prefix": "ss_generateResetToken",
